# Minimal Mosquitto config for the OPTIONAL bundled broker.
#
# Copy to mosquitto.conf before enabling the `mosquitto` service:
#   cp mosquitto/mosquitto.conf.example mosquitto/mosquitto.conf
#
# This allows anonymous connections — fine for a quick local test, but you
# should add authentication (password_file) and/or TLS before exposing it.

listener 1883
allow_anonymous true

persistence true
persistence_location /mosquitto/data/

log_dest stdout
log_type warning
log_type notice
log_type information
