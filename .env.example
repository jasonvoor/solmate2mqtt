# solmate2mqtt configuration — copy to `.env` and fill in.
#   cp .env.example .env
#
# Do NOT commit your real .env — it contains your SolMate password.

# ── SolMate cloud credentials (required) ────────────────────────────────────
# Your SolMate serial number (printed on the device / shown in the EET app).
SOLMATE_SERIAL=your-solmate-serial
# The password you use to log in to the SolMate web portal / app.
SOLMATE_PASSWORD=your-solmate-portal-password

# ── MQTT broker (required) ──────────────────────────────────────────────────
# Hostname/IP of your MQTT broker.
#   - Existing broker (e.g. HA's Mosquitto add-on): set its host/IP here.
#   - Bundled broker (uncomment `mosquitto` in docker-compose.yml): use `mosquitto`.
MQTT_HOST=your-broker-host
MQTT_PORT=1883
# Leave blank for an anonymous broker; otherwise set broker credentials.
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Topic layout (optional — defaults shown) ────────────────────────────────
# State topics are published under  <MQTT_PREFIX>/sensor/<DEVICE_ID>/<field>/state
MQTT_PREFIX=eet
# HA auto-discovery prefix — must match Home Assistant's MQTT discovery prefix
# (default in HA is `homeassistant`).
MQTT_DISCOVERY_PREFIX=homeassistant
# Identifies this SolMate; also the HA entity_id prefix: sensor.<DEVICE_ID>_<field>
DEVICE_ID=solmate

# ── Polling (optional — defaults shown) ─────────────────────────────────────
# Seconds between live-value polls.
TIMER_LIVE=30
# Seconds to wait before retrying after a connection drop.
TIMER_OFFLINE=60

# ── Misc (optional) ─────────────────────────────────────────────────────────
# DEBUG to see raw SDK payloads in the logs.
LOG_LEVEL=INFO
# Timezone for log timestamps.
TZ=UTC
